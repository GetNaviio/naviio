generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Plan {
  STARTER
  GROWTH
  PRO
  CFO
}

enum IntegrationProvider {
  PLAID
  QUICKBOOKS
  STRIPE
  XERO
  GUSTO
  ADP
  SHOPIFY
  GOHIGHLEVEL
  META_ADS
  GOOGLE_ADS
}

enum IntegrationStatus {
  CONNECTED
  ERROR
  DISCONNECTED
}

enum TransactionType {
  CREDIT
  DEBIT
}

enum ReportType {
  PNL
  CASHFLOW
  BALANCE_SHEET
  COMMENTARY
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

// Where an expense lands in the financial model. COGS = cost of revenue (drives
// gross margin); OPEX = operating expense; OTHER = excluded from gross-margin math.
enum ExpenseClass {
  COGS
  OPEX
  OTHER
}

// Role inside an organization. The org's creator (Organization.userId) is the
// implicit OWNER and has no OrgMember row; OrgMember rows are invited users.
enum OrgRole {
  OWNER
  MEMBER
  // A fractional CFO / CPA / financial professional with access to a client's
  // org. Can view and categorize, but not manage billing, disconnect
  // integrations, manage members, or delete the org (see lib/firm/access.ts).
  ADVISOR
}

// ─── Auth ─────────────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  image        String?
  passwordHash String?
  mfaEnabled   Boolean   @default(false)
  mfaSecret    String?   // encrypted TOTP secret
  // Account-deletion flag. Set on a deletion request; access is disabled
  // immediately and the record + all data are hard-deleted by the nightly purge
  // job 30 days later (SEC-POL-003 §5.2 grace window).
  deletedAt    DateTime?
  // Which org the user is currently working in (must be one they own or belong
  // to — validated on every resolve, so a revoked membership falls back safely).
  activeOrgId  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  organizations Organization[]
  credentials   Credential[]
  memberships   OrgMember[]
}

// WebAuthn / passkey credentials (second factor or passwordless). One row per
// registered authenticator; see @simplewebauthn/server data model.
model Credential {
  id             String   @id // Base64URL credential ID
  userId         String
  publicKey      Bytes
  counter        Int      @default(0)
  deviceType     String   // 'singleDevice' | 'multiDevice'
  backedUp       Boolean  @default(false)
  transports     String?  // CSV: 'internal','hybrid','usb','nfc','ble'
  webauthnUserID String
  name           String?  // user-facing label
  createdAt      DateTime @default(now())
  lastUsedAt     DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([webauthnUserID])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Organization ─────────────────────────────────────────────────────────────

model Organization {
  id                   String   @id @default(cuid())
  name                 String
  userId               String
  plan                 Plan     @default(STARTER)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  // White-label (CFO Suite): a client entity's own brand on the portal and
  // exported reports. logoUrl is an https image URL; brandColor a #hex accent.
  // hideNaviioBranding minimizes the "Powered by Navi" mark where allowed.
  brandLogoUrl         String?
  brandColor           String?
  hideNaviioBranding   Boolean  @default(false)
  // The fractional-CFO firm that manages this client org, if any. Set when a
  // client accepts a firm's invite; the firm grouping drives the CFO's client
  // roster, white-label, and (later) firm-level billing. Access control still
  // lives in OrgMember — the firm link is organizational, not an auth grant.
  firmId               String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  owner             User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  firm              Firm?               @relation(fields: [firmId], references: [id])
  integrations      Integration[]
  transactions      Transaction[]
  categories        Category[]
  reports           Report[]
  alerts            Alert[]
  mrrSnapshots      MrrSnapshot[]
  txnClassifications TxnClassification[]
  creditAccount     CreditAccount?
  creditLedger      CreditLedgerEntry[]
  forecastScenarios ForecastScenario[]
  workforceRoles    WorkforceRole[]
  budgetLines       BudgetLine[]
  integrationRequests IntegrationRequest[]
  adInsights        AdInsight[]
  members           OrgMember[]
  invitations       Invitation[]
  portalShares      PortalShare[]
  decisionLogs      DecisionLog[]

  @@index([userId])
}

/**
 * Navi Decision Engine log — one row per computed decision (affordability,
 * capex, runway). This is the proprietary, compounding dataset behind the moat:
 * the question asked, the inputs/assumptions, and the verdict, plus an optional
 * realized OUTCOME captured later (did they do it? what happened?). The full
 * engine answer is snapshotted as JSON so the historical reasoning is auditable.
 * No customer money math is stored beyond what the engine produced.
 */
model DecisionLog {
  id          String   @id @default(cuid())
  orgId       String
  userId      String
  template    String   // 'affordability' | 'capex' | 'runway_path'
  question    String?  // the natural-language question, when asked in chat
  verdict     String   // 'yes' | 'no' | 'conditional'
  headline    String
  confidence  String   // 'high' | 'medium' | 'low'
  params      Json     // the inputs/assumptions used
  answer      Json     // full answer-contract snapshot
  // Outcome loop (filled in later): did the user act, and what happened?
  outcome      String?  // e.g. 'proceeded' | 'declined' | 'deferred'
  outcomeNote  String?
  outcomeAt    DateTime?
  followedUpAt DateTime? // when Navi prompted for the outcome (dedup for the cron)
  createdAt    DateTime @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([orgId, template])
}

/**
 * Client portal share (CFO Suite): a read-only, login-less link a CFO sends
 * a client to view this org's headline financials. Only a SHA-256 hash of the
 * token is stored — the raw link is shown once at creation. Revocable
 * (revokedAt) and optionally time-boxed (expiresAt). `scopes` is a CSV of the
 * sections the link may show (pnl, cash, kpis), so a CFO can share a cash-only
 * view without exposing the full P&L.
 */
model PortalShare {
  id           String    @id @default(cuid())
  orgId        String
  label        String    // who/what this link is for, e.g. "Q2 board view"
  tokenHash    String    @unique
  scopes       String    @default("pnl,cash,kpis")
  createdById  String
  expiresAt    DateTime?
  revokedAt    DateTime?
  lastViewedAt DateTime?
  viewCount    Int       @default(0)
  createdAt    DateTime  @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}

/**
 * Team membership: one row per invited user in an org. The org creator is the
 * implicit OWNER (Organization.userId) and never has a row here — that keeps
 * the existing single-user data model untouched and needs no backfill.
 */
model OrgMember {
  id        String   @id @default(cuid())
  orgId     String
  userId    String
  role      OrgRole  @default(MEMBER)
  createdAt DateTime @default(now())

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@index([userId])
}

/**
 * Pending team invite. Only a SHA-256 hash of the invite token is stored — the
 * raw link is shown once at creation (re-inviting regenerates it). Accepting
 * requires the logged-in user's email to match, so the link alone is not a
 * bearer credential. One live invite per (org, email); re-invites upsert.
 */
model Invitation {
  id          String    @id @default(cuid())
  orgId       String
  email       String
  role        OrgRole   @default(MEMBER)
  tokenHash   String    @unique
  invitedById String
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, email])
  @@index([orgId])
}

// ─── Fractional-CFO firm (white-label / multi-client) ───────────────────────────

/**
 * A fractional CFO / CPA practice. The firm owner (ownerUserId) manages a roster
 * of client Organizations. Access to each client is still granted per-org via an
 * OrgMember row with role ADVISOR — the Firm is the organizational/branding/billing
 * grouping on top, never an implicit auth grant. All new-feature reads/writes go
 * through raw SQL helpers (lib/firm/*), so this model does not require a Prisma
 * client regeneration to be used.
 */
model Firm {
  id           String   @id @default(cuid())
  ownerUserId  String   // the CFO who owns the practice (loose ref; no cascade)
  name         String
  brandLogoUrl String?  // white-label: https logo URL shown on the client portal
  brandColor   String?  // white-label: #hex accent
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  clients       Organization[]
  clientInvites ClientInvite[]

  @@index([ownerUserId])
}

/**
 * A firm's invitation for a prospective client to join Naviio under that firm.
 * The client always creates/owns their OWN login and org (client-led model): on
 * accept, we ensure the client has their org, add the inviting advisor as an
 * ADVISOR member, set Organization.firmId, and record the client's explicit
 * consent (acceptedAt + consentScopes). Only a SHA-256 hash of the token is
 * stored; the raw link is shown once at creation.
 */
model ClientInvite {
  id            String    @id @default(cuid())
  firmId        String
  advisorUserId String    // who sent it (loose ref)
  clientEmail   String
  clientName    String?
  tokenHash     String    @unique
  status        String    @default("pending") // pending | accepted | revoked | expired
  consentScopes String    @default("financials") // CSV of what the advisor may see
  orgId         String?   // the client's org, filled on accept
  expiresAt     DateTime
  acceptedAt    DateTime?
  createdAt     DateTime  @default(now())

  firm Firm @relation(fields: [firmId], references: [id], onDelete: Cascade)

  @@index([firmId])
  @@index([clientEmail])
}

/**
 * Lightweight access audit: who (actorUserId) touched which client org (orgId)
 * and what they did (action). Powers the advisor-access transparency trail the
 * client and SOC 2 reviewers expect. Append-only; no money math stored.
 */
model AccessLog {
  id          String   @id @default(cuid())
  orgId       String
  actorUserId String
  action      String   // 'switch' | 'view' | 'export' | 'reclassify' | 'add_client' | ...
  detail      String?
  createdAt   DateTime @default(now())

  @@index([orgId, createdAt])
  @@index([actorUserId])
}

// ─── External document sharing (files live OUTSIDE Naviio) ───────────────────────

/**
 * An OAuth connection to an external file-sharing platform (Dropbox, Google
 * Drive). Documents themselves NEVER live in Naviio — only the connection and
 * pointers (DocumentRef) do. Tokens are app-encrypted with lib/crypto before
 * being written via the raw-SQL helpers in lib/documents (the Prisma
 * field-encryption extension only covers the Integration model).
 */
model DocumentSource {
  id           String    @id @default(cuid())
  orgId        String
  provider     String    // 'dropbox' | 'google_drive'
  accessToken  String?   @db.Text // app-encrypted (encv1:...)
  refreshToken String?   @db.Text // app-encrypted
  accountLabel String?   // the connected account's display name/email
  rootPath     String    @default("") // optional folder scope
  expiresAt    DateTime?
  status       String    @default("connected") // connected | error | disconnected
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([orgId, provider])
  @@index([orgId])
}

/**
 * A pointer to a file that lives in the external platform and has been shared
 * into this client's workspace (by the client or the advisor). Stores metadata
 * and an outbound link ONLY — never the file contents.
 */
model DocumentRef {
  id             String    @id @default(cuid())
  orgId          String
  provider       String    // 'dropbox' | 'google_drive'
  externalId     String    // provider file id / path_lower
  name           String
  path           String?
  url            String?   // outbound link to open the file in the external platform
  sizeBytes      Int?
  sharedByUserId String?
  modifiedAt     DateTime?
  createdAt      DateTime  @default(now())

  @@unique([orgId, provider, externalId])
  @@index([orgId])
}

/**
 * One row per (org, ad platform, ad account, day): the platform-reported
 * spend and KPIs from Meta/Google Ads. Daily grain on purpose — ad platforms
 * bill in irregular windows (thresholds, month-end), so the bank-charge
 * matcher sums whatever span of days reconciles against the charge amount.
 * Money is Decimal like every other money column.
 */
model AdInsight {
  id              String              @id @default(cuid())
  orgId           String
  provider        IntegrationProvider
  accountId       String
  accountName     String?
  date            String // 'YYYY-MM-DD' UTC, lexically ordered like months
  spend           Decimal             @db.Decimal(19, 4)
  impressions     Int                 @default(0)
  clicks          Int                 @default(0)
  conversions     Float               @default(0)
  conversionValue Decimal?            @db.Decimal(19, 4)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, provider, accountId, date])
  @@index([orgId, provider, date])
}

/**
 * A vote for a not-yet-built connector from the integrations catalog.
 * One row per (org, slug) — roadmap priority = count of rows per slug, so we
 * build what users actually ask for. Slug is a catalog slug
 * (src/lib/integrations/catalog.ts), intentionally a String not an enum so
 * adding catalog entries never needs a migration.
 */
model IntegrationRequest {
  id        String   @id @default(cuid())
  orgId     String
  slug      String
  createdAt DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, slug])
  @@index([slug])
}

/**
 * Per-subscription MRR captured once per month. Enables real NRR, the MRR
 * waterfall (new/expansion/contraction/churned), and cohort retention by
 * comparing a subscription's MRR across periods. One row per (org, sub, period).
 */
model MrrSnapshot {
  id             String   @id @default(cuid())
  orgId          String
  period         String   // 'YYYY-MM' of the snapshot month
  subscriptionId String   // Stripe subscription id
  customerId     String?
  mrr            Decimal  @db.Decimal(19, 4) // monthly recurring value, major units (exact — no float drift)
  status         String   // active, past_due, canceled, …
  cohortMonth    String   // 'YYYY-MM' the subscription first started
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, subscriptionId, period])
  @@index([orgId, period])
  @@index([orgId, cohortMonth])
}

// ─── Integrations ─────────────────────────────────────────────────────────────

model Integration {
  id           String              @id @default(cuid())
  orgId        String
  provider     IntegrationProvider
  accessToken  String?             @db.Text
  refreshToken String?             @db.Text
  realmId      String?
  itemId       String?
  // Plaid /transactions/sync cursor — persisted so syncs are incremental
  transactionCursor String?         @db.Text
  expiresAt    DateTime?
  lastSyncedAt DateTime?
  status       IntegrationStatus   @default(CONNECTED)
  // Plaid NEW_ACCOUNTS_AVAILABLE webhook → prompt the user to add accounts via
  // update mode (account_selection_enabled). Distinct from status: the item is
  // still healthy/CONNECTED; this just flags that new accounts can be added.
  newAccountsAvailable Boolean      @default(false)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  organization Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([orgId, provider])
  @@index([orgId, status])
  // Webhooks arrive keyed by Plaid item_id — index for fast org lookup
  @@index([itemId])
}

// ─── Transactions ─────────────────────────────────────────────────────────────

model Transaction {
  id            String          @id @default(cuid())
  orgId         String
  integrationId String?
  // Provider transaction id. Unique PER ORG (not globally): two orgs syncing the
  // same provider must never collide, and uniqueness scoped by orgId means every
  // upsert is tenant-isolated by construction.
  externalId    String
  date          DateTime
  // Money is exact Decimal — never Float (IEEE 754 drift compounds in P&L math).
  amount        Decimal         @db.Decimal(19, 4)
  currency      String          @default("USD")
  description   String
  category      String?
  merchantName  String?
  accountId     String?
  type          TransactionType
  source        String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @default(now()) @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  integration  Integration?  @relation(fields: [integrationId], references: [id], onDelete: SetNull)

  @@unique([orgId, externalId])
  @@index([orgId, date])
  @@index([orgId, category])
  @@index([orgId, type, date]) // P&L groupBy(type) over date ranges
  @@index([integrationId])
}

// ─── Categories ───────────────────────────────────────────────────────────────

model Category {
  id       String  @id @default(cuid())
  orgId    String
  name     String
  color    String?
  parentId String?

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  parent       Category?    @relation("CategoryTree", fields: [parentId], references: [id])
  children     Category[]   @relation("CategoryTree")

  @@index([orgId])
  @@index([parentId])
}

// ─── Reports ──────────────────────────────────────────────────────────────────

model Report {
  id          String     @id @default(cuid())
  orgId       String
  type        ReportType
  data        Json
  period      String
  generatedAt DateTime   @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, type])
  @@index([orgId, period])
}

// ─── Alerts ───────────────────────────────────────────────────────────────────

model Alert {
  id        String        @id @default(cuid())
  orgId     String
  type      String
  message   String
  severity  AlertSeverity @default(INFO)
  isRead    Boolean       @default(false)
  createdAt DateTime      @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, isRead])
  @@index([orgId, severity])
  @@index([orgId, createdAt])
}

// ─── Waitlist ─────────────────────────────────────────────────────────────────

model Waitlist {
  id        String   @id @default(cuid())
  email     String
  product   String   @default("app") // "app" = main product, "card" = Naviio Card
  createdAt DateTime @default(now())

  @@unique([email, product]) // a person may join both the app and card waitlists
}

// ─── Financial model: COGS/OpEx overrides ──────────────────────────────────────

// A user's manual classification of a transaction as COGS / OpEx / Other.
// Keyed by the transaction's stable externalId so the tag survives re-syncs
// (transactions are upserted by externalId and would otherwise overwrite a column).
model TxnClassification {
  id           String        @id @default(cuid())
  orgId        String
  externalId   String        // Transaction.externalId this override applies to
  // Either (or both) may be set: expenseClass drives the model's gross-margin
  // math; category overrides the display label on Expenses/P&L drill-downs.
  expenseClass ExpenseClass?
  category     String?
  note         String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, externalId])
  @@index([orgId])
}

// Cross-org "community" categorization prior. When a user reclassifies a vendor,
// we record one anonymized vote here: (vendorKey → category, count). It holds NO
// amounts, NO org or user identity, and NO transaction detail — only a normalized
// merchant string and the agreed label — so it can be shared across orgs to fill
// vendors a given org hasn't fixed and the heuristics couldn't name. This is the
// compounding, proprietary dataset behind the categorization moat.
model VendorCategoryStat {
  id         String   @id @default(cuid())
  vendorKey  String   // normalized merchant identity (see classify.vendorKey)
  category   String   // a USER_CATEGORIES label
  count      Int      @default(1)
  updatedAt  DateTime @updatedAt

  @@unique([vendorKey, category])
  @@index([vendorKey])
}

// Peer-benchmark aggregates: how much businesses (by size band) spend per recurring
// vendor, as a privacy-preserving HISTOGRAM — counts of distinct orgs per spend
// bucket. NO amounts tied to any org, NO org identity. Rebuilt nightly. A benchmark
// is only ever surfaced when a (vendorKey, segment) has >= 5 orgs total (k-anon).
model VendorSpendStat {
  id        String   @id @default(cuid())
  vendorKey String   // normalized merchant identity
  segment   String   // size band (e.g. "1m_5m")
  bucket    Int      // half-octave monthly-$ bucket index (see lib/benchmarks/buckets)
  orgs      Int      @default(0) // distinct orgs in this bucket
  updatedAt DateTime @updatedAt

  @@unique([vendorKey, segment, bucket])
  @@index([segment, vendorKey])
}

// Peer-benchmark aggregates for spend-as-%-of-revenue by category and size band.
// Same privacy posture as VendorSpendStat: histogram of distinct-org counts per
// percent bucket, no amounts/identity. Surfaced only at >= 5 orgs (k-anon).
model CategorySpendStat {
  id        String   @id @default(cuid())
  category  String   // a USER_CATEGORIES label
  segment   String   // size band
  bucket    Int      // 0.5%-of-revenue bucket index (see lib/benchmarks/buckets)
  orgs      Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([category, segment, bucket])
  @@index([segment, category])
}

// Monthly snapshot of the vendor peer-median (per size band) so we can show how
// peers' prices for a vendor trend over time ("similar businesses now pay 8%
// more"). One row per (vendor, segment, month); k-anon already applied upstream.
model VendorBenchmarkSnapshot {
  id        String   @id @default(cuid())
  vendorKey String
  segment   String
  period    String   // YYYY-MM
  median    Int      // peer median monthly $ for that month
  orgs      Int
  createdAt DateTime @default(now())

  @@unique([vendorKey, segment, period])
  @@index([vendorKey, segment])
}

// ─── Forecast scenarios ─────────────────────────────────────────────────────────

// User-defined forecast scenarios (multipliers applied to the base projection).
// The built-in bear/base/bull cases live in code (DEFAULT_SCENARIOS); only
// custom scenarios are persisted. Previously held in a module-level array —
// lost on every restart and not org-scoped.
model ForecastScenario {
  id                   String   @id @default(cuid())
  orgId                String
  name                 String
  growthMultiplier     Float
  churnMultiplier      Float
  opexGrowthMultiplier Float
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, createdAt])
}

// ─── FP&A planning models ────────────────────────────────────────────────────────

// A planned role in the workforce model. Cost contribution for a month m is
// headcount × monthlySalary × (1 + loadedPct/100) when startMonth ≤ m ≤ endMonth
// (endMonth null = ongoing). Months are 'YYYY-MM' strings (lexically ordered).
model WorkforceRole {
  id            String   @id @default(cuid())
  orgId         String
  title         String
  department    String?  // optional cost-center dimension (Engineering, Sales, G&A, …)
  headcount     Int      @default(1)
  monthlySalary Decimal  @db.Decimal(19, 4) // per person, gross monthly
  loadedPct     Float    @default(25)       // employer taxes/benefits/tools uplift %
  startMonth    String   // 'YYYY-MM'
  endMonth      String?  // 'YYYY-MM' inclusive; null = ongoing
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}

enum BudgetLineKind {
  REVENUE
  COGS
  OPEX
}

// One budgeted amount per org × month × P&L line. Actuals come from the ledger
// at read time — only the plan is stored.
model BudgetLine {
  id        String         @id @default(cuid())
  orgId     String
  month     String         // 'YYYY-MM'
  line      BudgetLineKind
  amount    Decimal        @db.Decimal(19, 4)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, month, line])
  @@index([orgId, month])
}

// ─── Credits / usage-based billing ──────────────────────────────────────────────

// One credit balance per org. `balance` is in whole credits. The authoritative
// history is CreditLedgerEntry; this row is the fast-read running total, always
// updated in the same transaction as a ledger entry.
model CreditAccount {
  id        String   @id @default(cuid())
  orgId     String   @unique
  balance   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

// Append-only ledger of every credit change: positive `delta` = purchase/grant,
// negative = a metered feature charge. `balanceAfter` snapshots the running total.
model CreditLedgerEntry {
  id           String   @id @default(cuid())
  orgId        String
  delta        Int      // + credits added, - credits charged
  balanceAfter Int
  reason       String   // 'purchase' | 'grant' | 'charge' | 'refund'
  feature      String?  // 'navi_message' | 'realtime_refresh' (charges)
  // Stripe Checkout session id (purchases only). UNIQUE so a concurrent
  // webhook + return-confirm can't double-credit one payment (Postgres permits
  // multiple NULLs, so charge/refund/grant rows are unaffected).
  stripeRef    String?  @unique
  createdAt    DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, createdAt])
}
