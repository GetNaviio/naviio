# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000
JWT_SECRET=your-jwt-secret-change-in-production

# OpenAI — used only for Navi's high-quality text-to-speech voice (tts-1-hd).
# If unset, Navi falls back to the browser's built-in voice. platform.openai.com/api-keys
OPENAI_API_KEY=

# ─── Sign-in providers ───────────────────────────────────────────────────────
# Google OAuth (Continue with Google). Create at console.cloud.google.com →
# APIs & Services → Credentials → OAuth client (Web). Authorized redirect URI:
#   https://<your-domain>/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-domain.example/api/auth/google/callback

# WorkOS SSO (enterprise SAML/OIDC). dashboard.workos.com → API keys + redirect.
#   Redirect URI: https://<your-domain>/api/auth/sso/callback
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_REDIRECT_URI=https://your-domain.example/api/auth/sso/callback

# Application-layer encryption key for stored OAuth tokens (SEC-POL-001 §3.1).
# 32 bytes, hex (64 chars) or base64. Generate:  openssl rand -base64 32
# REQUIRED in production. If unset, tokens are stored unencrypted (dev only).
# Must remain STABLE — rotating it makes existing encrypted tokens unreadable
# (users would need to reconnect their integrations).
TOKEN_ENCRYPTION_KEY=

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/navio

# ─── AI ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# Optional: Together AI for cheap open-model slot extraction (Navi decision flow).
# When set, /api/navi/extract prefers Together, then falls back to Anthropic, then
# to the deterministic regex extractor. OpenAI-compatible; no SDK required.
TOGETHER_API_KEY=
TOGETHER_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo
# Optional: let the in-product Navi agent use web search (Anthropic server-side
# tool) for market/benchmark questions. Off unless set to 1.
NAVI_WEB_SEARCH=0

# ─── Plaid ────────────────────────────────────────────────────────────────────
PLAID_CLIENT_ID=your_plaid_client_id
# Use your PRODUCTION secret when PLAID_ENV=production (Plaid has separate
# secrets per environment).
PLAID_SECRET=your_plaid_secret
# sandbox | production
PLAID_ENV=sandbox
# Public HTTPS URL Plaid POSTs item/transaction webhooks to. Must be reachable
# from the internet (in dev, your ngrok URL). Point it at the webhook route:
#   https://<your-domain>/api/auth/plaid/webhook
PLAID_WEBHOOK_URL=https://your-domain.example/api/auth/plaid/webhook
# OAuth return page for OAuth banks. Register the exact value under
# Developers → API → Allowed redirect URIs in the Plaid dashboard.
#   https://<your-domain>/integrations/oauth
PLAID_REDIRECT_URI=https://your-domain.example/integrations/oauth

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_CLIENT_ID=ca_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_REDIRECT_URI=http://localhost:3000/api/auth/stripe/callback
# Webhook secret for the CREDIT-PURCHASE endpoint (/api/credits/webhook). In dev:
#   stripe listen --forward-to localhost:3000/api/credits/webhook
# then paste the printed whsec_... here. Falls back to STRIPE_WEBHOOK_SECRET if unset.
STRIPE_CREDITS_WEBHOOK_SECRET=whsec_...
# ⚠️ TEMPORARY (sandbox testing only) — set to 1 to show a "paste a Stripe test
# key" box on the Integrations page, bypassing OAuth to read the seeded sandbox
# account. Leave unset/0 in production. Scheduled for removal.
NEXT_PUBLIC_STRIPE_KEY_CONNECT=0

# ─── Cron / scheduled sync ────────────────────────────────────────────────────
# Secret for the /api/cron/sync endpoint. Sent as: Authorization: Bearer <value>.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=replace_with_a_long_random_string

# ─── QuickBooks Online ────────────────────────────────────────────────────────
QB_CLIENT_ID=your_qbo_client_id
QB_CLIENT_SECRET=your_qbo_client_secret
QB_ENV=sandbox
QB_REDIRECT_URI=http://localhost:3000/api/auth/quickbooks/callback

# ─── Xero ─────────────────────────────────────────────────────────────────────
XERO_CLIENT_ID=your_xero_client_id
XERO_CLIENT_SECRET=your_xero_client_secret
XERO_REDIRECT_URI=http://localhost:3000/api/auth/xero/callback

# ─── Dropbox (external document sharing) ──────────────────────────────────────
# Read-only file sharing for the fractional-CFO product. Files live in Dropbox;
# Naviio stores only the OAuth connection and pointers. Leave unset to hide the
# "Connect Dropbox" option. Scopes: files.metadata.read, files.content.read,
# account_info.read, sharing.read.
DROPBOX_CLIENT_ID=your_dropbox_app_key
DROPBOX_CLIENT_SECRET=your_dropbox_app_secret
DROPBOX_REDIRECT_URI=http://localhost:3000/api/auth/dropbox/callback

# ─── Firm billing / Stripe Connect (fractional-CFO SaaS resale) ───────────────
# Signing secret for the Connect webhook (POST /api/firm/connect/webhook) that
# auto-flips a firm's Connect status to enabled on account.updated. Falls back to
# STRIPE_WEBHOOK_SECRET if unset. Uses the existing STRIPE_SECRET_KEY.
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_your_connect_webhook_secret
# Signing secret for the firm platform-subscription webhook
# (POST /api/firm/billing/webhook; customer.subscription.updated/deleted →
# Firm.subscriptionStatus). Falls back to STRIPE_WEBHOOK_SECRET if unset.
STRIPE_FIRM_WEBHOOK_SECRET=whsec_your_firm_billing_webhook_secret

# Firm platform-subscription price IDs (base + per-org overage as a graduated
# tiered price). Generate with: node scripts/stripe-firm-prices.cjs
# (run once per Stripe mode — test and live IDs differ).
STRIPE_FIRM_PRICE_WL_MONTHLY=price_...
STRIPE_FIRM_PRICE_WL_ANNUAL=price_...
STRIPE_FIRM_PRICE_WLSAAS_MONTHLY=price_...
STRIPE_FIRM_PRICE_WLSAAS_ANNUAL=price_...

# ─── GoHighLevel ──────────────────────────────────────────────────────────────
GHL_CLIENT_ID=your_ghl_client_id
GHL_CLIENT_SECRET=your_ghl_client_secret
GHL_REDIRECT_URI=http://localhost:3000/api/auth/ghl/callback

# ─── Gusto ────────────────────────────────────────────────────────────────────
GUSTO_CLIENT_ID=your_gusto_client_id
GUSTO_CLIENT_SECRET=your_gusto_client_secret
GUSTO_REDIRECT_URI=http://localhost:3000/api/auth/gusto/callback
GUSTO_ENV=demo

# ─── ADP (requires approved developer partner credentials) ────────────────────
ADP_CLIENT_ID=your_adp_client_id
ADP_CLIENT_SECRET=your_adp_client_secret
ADP_REDIRECT_URI=http://localhost:3000/api/auth/adp/callback

# ─── Shopify ──────────────────────────────────────────────────────────────────
SHOPIFY_CLIENT_ID=your_shopify_api_key
SHOPIFY_CLIENT_SECRET=your_shopify_api_secret
SHOPIFY_REDIRECT_URI=http://localhost:3000/api/auth/shopify/callback

# Admin allowlist — comma-separated emails allowed to access internal admin
# views (e.g. GET /api/waitlist). Unset = nobody (fails closed).
ADMIN_EMAILS=""
